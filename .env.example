# =============================================================================
# nas-setup/.env.example
# Copia a .env y configura tus valores. NUNCA hagas commit de .env.
#
#   cp .env.example .env
#   nano .env
#   sudo bash install.sh
# =============================================================================

# ── Módulo 1: NFS ─────────────────────────────────────────────────────────────

# Share NFS principal — directorio que se exporta vía NFS
# Este es el path usado actualmente por el CSI driver de Kubernetes
NFS_SHARE_DIR=/nfs/kahunaz

# Shares adicionales separados por dos puntos (:)
# Ejemplo: /armhot:/mergerfs/pool
# Dejar vacío si solo usas NFS_SHARE_DIR
NFS_EXTRA_DIRS=

# Red a la que se permite montar las shares NFS
NFS_ALLOWED_NETWORK=192.168.0.0/24

# Opciones de export NFS (man exports para referencia)
NFS_EXPORT_OPTIONS="rw,sync,no_subtree_check,no_root_squash"

# ── Módulo 1: Samba ───────────────────────────────────────────────────────────

# Nombre del grupo de trabajo Windows
SAMBA_WORKGROUP=WORKGROUP

# Usuario Samba (se crea como usuario del sistema sin login)
SAMBA_USER=nasuser

# Contraseña Samba — usa una contraseña segura en producción
SAMBA_PASSWORD=changeme

# Nombre visible de la share en el explorador de Windows/macOS
SAMBA_SHARE_NAME=NAS

# Nivel de log Samba: 0=solo errores, 1=normal, 3=verbose
SAMBA_LOG_LEVEL=1

# ── Módulo 2: MergerFS ────────────────────────────────────────────────────────

# Punto de montaje del pool unificado MergerFS
MERGERFS_POOL_PATH=/mergerfs/pool

# Política de escritura MergerFS:
#   mfs = most free space (recomendado — distribuye en disco con más espacio)
#   lfs = least free space
#   ff  = first found (siempre escribe en el primer disco disponible)
MERGERFS_CREATE_POLICY=mfs

# Prefijo para los puntos de montaje de discos individuales
# Disco 1 DATA  → /mnt/data1
# Disco 2 DATA  → /mnt/data2
# Disco 1 PARITY → /mnt/parity1
DISK_MOUNT_PREFIX=/mnt

# ── Módulo 2: SnapRAID ────────────────────────────────────────────────────────

# Hora (0-23) para ejecutar el sync diario de paridad
SNAPRAID_SYNC_HOUR=3

# Día de la semana para el scrub semanal
# Valores: Mon, Tue, Wed, Thu, Fri, Sat, Sun
SNAPRAID_SCRUB_DAY=Sun

# Porcentaje de datos a verificar en cada scrub semanal
# 5% es el valor recomendado (cubre el 100% mensualmente)
SNAPRAID_SCRUB_PERCENT=5

# Umbral de seguridad: si más del N% de archivos fueron eliminados
# desde el último sync, aborta el sync automático (previene propagación
# de borrados accidentales a la paridad)
SNAPRAID_DIFF_THRESHOLD=20

# Backend de scheduling: systemd (recomendado) o cron
SCHEDULE_TYPE=systemd

# ── Módulo 3: Integración Kubernetes ─────────────────────────────────────────
# (Módulo en desarrollo — configura cuando estés listo para usarlo)

# Ruta absoluta al repositorio k8-homelab en esta máquina
K8S_HOMELAB_PATH=/home/jgomez/k8-homelab

# Namespace de Kubernetes para los PVCs generados
K8S_PV_NAMESPACE=file-share

# Directorio donde se guardan los manifests YAML generados
K8S_MANIFESTS_OUTPUT=./generated/k8s

# ── General ───────────────────────────────────────────────────────────────────

# Nivel de log: INFO (normal) o DEBUG (verbose)
LOG_LEVEL=INFO

# Forzar re-ejecución ignorando estados guardados
# Útil si quieres reconfigurar algo que ya se ejecutó
# 0 = normal, 1 = forzar re-run
FORCE_RERUN=0
